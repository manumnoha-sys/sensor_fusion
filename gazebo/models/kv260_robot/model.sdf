<?xml version="1.0" ?>
<!--
  KV260 Robot Model
  Camera specs match ON Semi AR1335 (3MP, 1/3.2" CMOS) via AP1302 ISP:
    - Resolution: 1920x1080 @ 30fps (hardware capture mode)
    - HFOV: 1.3439 rad (~77°) — 1/3.2" sensor with ~3.5mm lens
    - Depth of field: 0.02m - 300m
  IMU: 6-DOF (accel + gyro), 200 Hz
-->
<sdf version="1.9">
  <model name="kv260_robot">

    <link name="base_link">
      <!-- Chassis -->
      <inertial>
        <mass>1.5</mass>
        <inertia><ixx>0.0281</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0341</iyy><iyz>0</iyz><izz>0.0436</izz></inertia>
      </inertial>
      <collision name="chassis_collision">
        <geometry><box><size>0.2 0.15 0.05</size></box></geometry>
      </collision>
      <visual name="chassis_visual">
        <geometry><box><size>0.2 0.15 0.05</size></box></geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>

      <!-- Camera mount post -->
      <visual name="camera_post_visual">
        <pose>0.0 0 0.06 0 0 0</pose>
        <geometry><cylinder><radius>0.008</radius><length>0.07</length></cylinder></geometry>
        <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
      </visual>

      <!-- KV260 board representation -->
      <visual name="kv260_board_visual">
        <pose>0 0 0.03 0 0 0</pose>
        <geometry><box><size>0.12 0.07 0.003</size></box></geometry>
        <material><ambient>0.0 0.4 0.0 1</ambient><diffuse>0.0 0.4 0.0 1</diffuse></material>
      </visual>
    </link>

    <!-- Left wheel -->
    <link name="left_wheel">
      <pose>0.0 0.09 0 -1.5707963 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia><ixx>0.000233</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000233</iyy><iyz>0</iyz><izz>0.000400</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
    </link>

    <!-- Right wheel -->
    <link name="right_wheel">
      <pose>0.0 -0.09 0 -1.5707963 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia><ixx>0.000233</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000233</iyy><iyz>0</iyz><izz>0.000400</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
    </link>

    <!-- Camera link — matches AR1335 + AP1302 ISP specs -->
    <link name="camera_link">
      <pose>0.1 0 0.095 0 0 0</pose>
      <inertial>
        <mass>0.02</mass>
        <inertia><ixx>1e-5</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1e-5</iyy><iyz>0</iyz><izz>1e-5</izz></inertia>
      </inertial>
      <visual name="camera_body">
        <geometry><box><size>0.025 0.025 0.025</size></box></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material>
      </visual>
      <visual name="lens">
        <pose>0.013 0 0 0 1.5707963 0</pose>
        <geometry><cylinder><radius>0.006</radius><length>0.006</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.4 1</ambient><diffuse>0.1 0.1 0.4 1</diffuse></material>
      </visual>

      <!-- AR1335 camera sensor via AP1302 ISP (MIPI CSI-2 output) -->
      <sensor name="ar1335_camera" type="camera">
        <pose>0 0 0 0 0 0</pose>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>/kv260/camera/image_raw</topic>
        <camera name="ar1335">
          <!-- AR1335: 1/3.2" sensor, ~3.5mm focal length → ~77° HFOV at 1080p -->
          <horizontal_fov>1.3439</horizontal_fov>
          <image>
            <width>1920</width>
            <height>1080</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.02</near>
            <far>300</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.005</stddev>
          </noise>
          <distortion>
            <k1>-0.28</k1>
            <k2>0.07</k2>
            <k3>0.0</k3>
            <p1>0.0</p1>
            <p2>0.0</p2>
            <center>0.5 0.5</center>
          </distortion>
        </camera>
      </sensor>
    </link>

    <!-- IMU link — co-located with camera (typical IAS module) -->
    <link name="imu_link">
      <pose>0 0 0.03 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia><ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1e-6</iyy><iyz>0</iyz><izz>1e-6</izz></inertia>
      </inertial>

      <!-- 6-DOF IMU: accelerometer + gyroscope at 200 Hz -->
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>200</update_rate>
        <topic>/kv260/imu/data_raw</topic>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev><bias_mean>7.5e-6</bias_mean><bias_stddev>8e-7</bias_stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev><bias_mean>7.5e-6</bias_mean><bias_stddev>8e-7</bias_stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev><bias_mean>7.5e-6</bias_mean><bias_stddev>8e-7</bias_stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev><bias_mean>1e-1</bias_mean><bias_stddev>1e-3</bias_stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev><bias_mean>1e-1</bias_mean><bias_stddev>1e-3</bias_stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev><bias_mean>1e-1</bias_mean><bias_stddev>1e-3</bias_stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>

    <!-- Joints -->
    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent><child>left_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent><child>right_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent><child>camera_link</child>
    </joint>

    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent><child>imu_link</child>
    </joint>

    <!-- Differential drive plugin -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.18</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/kv260/cmd_vel</topic>
      <odom_topic>/kv260/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

    <!-- Odometry publisher -->
    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>

  </model>
</sdf>
